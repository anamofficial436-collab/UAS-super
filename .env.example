# ============================================================
#  .env.example — Template kredensial untuk UAS Project
#  Salin file ini ke .env dan isi dengan nilai yang sesuai.
#  JANGAN commit file .env ke repository!
# ============================================================

# ── Docker Hub ──────────────────────────────────────────────
DOCKERHUB_USERNAME=yourdockerhubusername

# ── MariaDB — Root ──────────────────────────────────────────
DB_ROOT_PASSWORD=supersecretrootpassword

# ── MariaDB — Aplikasi ──────────────────────────────────────
# DB_HOST harus sesuai dengan nama service di docker-compose.yml
DB_HOST=mariadb_db
DB_PORT=3306
DB_NAME=uas_db
DB_USER=uas_user
DB_PASSWORD=uas_password_secure
